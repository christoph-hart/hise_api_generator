        {
          "name": "preprocessorString",
          "type": "String"
        },
        {
          "name": "value",
          "type": "var"
        }
      ]
    },
    "setUniformData": {
      "signature": "void setUniformData(String id, var data)",
      "returnType": "void",
      "description": "Sets an uniform variable to be used in the shader code.",
      "parameters": [
        {
          "name": "id",
          "type": "String"
        },
        {
          "name": "data",
          "type": "var"
        }
      ]
    },
    "toBase64": {
      "signature": "String toBase64()",
      "returnType": "String",
      "description": "Compresses the GLSL code and returns a encoded string snippet.",
      "parameters": []
    }
