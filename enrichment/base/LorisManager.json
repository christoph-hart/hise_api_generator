        {
          "name": "file",
          "type": "var"
        },
        {
          "name": "parameter",
          "type": "String"
        },
        {
          "name": "harmonicIndex",
          "type": "int"
        }
      ]
    },
    "createSnapshot": {
      "signature": "var createSnapshot(var file, String parameter, double time)",
