        {
          "name": "file",
          "type": "var"
        },
        {
          "name": "parameter",
          "type": "String"
        },
        {
          "name": "harmonicIndex",
          "type": "int"
        }
      ]
    },
    "createEnvelopes": {
      "signature": "var createEnvelopes(var file, String parameter, int harmonicIndex)",
