{
  "className": "GlobalRoutingManager",
  "category": "object",
  "description": "",
  "methods": {
    "addOSCCallback": {
      "signature": "void addOSCCallback(String oscSubAddress, var callback)",
      "returnType": "void",
      "description": "Register a scripting callback to be executed when a OSC message that matches the subAddress is received.",
      "parameters": [
        {
          "name": "oscSubAddress",
          "type": "String"
        },
        {
          "name": "callback",
          "type": "var"
        }
      ]
    },
    "connectToOSC": {
      "signature": "bool connectToOSC(var connectionData, var errorFunction)",
      "returnType": "bool",
      "description": "Allows the global routing manager to send and receive OSC messages through the cables.",
      "parameters": [
        {
          "name": "connectionData",
          "type": "var"
        },
        {
          "name": "errorFunction",
          "type": "var"
        }
      ]
    },
    "getCable": {
      "signature": "var getCable(String cableId)",
      "returnType": "var",
      "description": "Returns a scripted reference to the global cable (and creates a cable with this ID if it can't be found.",
      "parameters": [
        {
          "name": "cableId",
          "type": "String"
        }
      ]
    },
    "getEventData": {
      "signature": "var getEventData(int eventId, int dataSlot)",
      "returnType": "var",
      "description": "Returns the double value that is written to the data slot using setEventData. If the event ID wasn't written, it will return undefined.",
      "parameters": [
        {
          "name": "eventId",
          "type": "int"
        },
        {
          "name": "dataSlot",
          "type": "int"
        }
      ]
    },
    "removeOSCCallback": {
      "signature": "bool removeOSCCallback(String oscSubAddress)",
      "returnType": "bool",
      "description": "Removes a OSC callback for the given address.",
      "parameters": [
        {
          "name": "oscSubAddress",
          "type": "String"
        }
      ]
    },
    "sendOSCMessage": {
      "signature": "bool sendOSCMessage(String oscSubAddress, var data)",
      "returnType": "bool",
      "description": "Send an OSC message to the output port.",
      "parameters": [
        {
          "name": "oscSubAddress",
          "type": "String"
        },
        {
          "name": "data",
          "type": "var"
        }
      ]
    },
    "setEventData": {
      "signature": "bool setEventData(int eventId, int dataSlot, double value)",
      "returnType": "bool",
      "description": "Writes a value into the given slot that can be retrieved using the event ID.",
      "parameters": [
        {
          "name": "eventId",
          "type": "int"
        },
        {
          "name": "dataSlot",
          "type": "int"
        },
        {
          "name": "value",
          "type": "double"
        }
      ]
    }
  }
}