{
  "groups": {
    "module-tree": "Audio engine, module tree navigation, and processor handles",
    "ui": "UI components, rendering, and visual tools",
    "data": "Containers, complex data references, and DSP utilities",
    "event": "Asynchronous events, callbacks, timing, and routing",
    "scriptnode": "ScriptNode DSP graph system",
    "services": "File I/O, networking, preset model, and standalone utilities"
  },
  "roles": {
    "handle": "Script handle to a module or resource managed elsewhere",
    "factory": "Creates and manages other API objects",
    "container": "Stores and organizes data or child elements",
    "component": "Visual UI component on the script interface",
    "utility": "Stateless helper functions and conversions",
    "service": "Singleton manager for a subsystem",
    "processor": "Performs DSP, analysis, or event processing",
    "event": "Routes or dispatches asynchronous events"
  },
